# --- Build & Deploy ---
# Vite log level (e.g. debug, info, warn, error)
VITE_LOG_LEVEL=debug
# Fly.io API token for deployment
FLY_API_TOKEN=

# --- Database ---
# PostgreSQL connection string (e.g. Supabase pooler URL)
DATABASE_URL=

# --- Auth (NextAuth / Auth.js) ---
# Auth.js secret for signing cookies/tokens. Generate with: npx auth
AUTH_SECRET=
# GitHub OAuth (app client ID and secret)
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Notion OAuth (integration ID, secret, callback URL)
AUTH_NOTION_ID=
AUTH_NOTION_SECRET=
AUTH_NOTION_REDIRECT_URI=
# NextAuth base URL (e.g. http://localhost:3000)
NEXTAUTH_URL=

# --- Supabase ---
# Supabase project URL and keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Storage ---
# Vercel Blob storage read-write token
BLOB_READ_WRITE_TOKEN=

# --- Third-party APIs ---
# Creem API key
CREEM_API_KEY=
# GitHub personal access token (for public client; use with care)
NEXT_PUBLIC_GITHUB_TOKEN=

# --- Agent / LLM ---
# Agent service (base URL and API key)
AGENT_BASE_URL=
AGENT_API_KEY=
# OpenRouter (management key for billing; API key for model requests)
OPEN_ROUTER_MANAGEMENT_KEY=
OPEN_ROUTER_API_KEY=

# --- Subscription / Billing ---
# ClawHub token; comma-separated emails exempt from subscription
CLAWHUB_TOKEN=
OPENCLAW_SUBSCRIPTION_EXEMPT_EMAILS=

# --- Google OAuth ---
# Google OAuth client ID and secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
