{
  "name": "openclaw-deploy",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "generate": "drizzle-kit generate",
    "migrate": "drizzle-kit push",
    "db:start": "docker-compose up -d",
    "db:stop": "docker-compose down",
    "db:restart": "docker-compose restart",
    "db:reset": "docker-compose down -v && docker-compose up -d && pnpm run migrate",
    "db:logs": "docker-compose logs -f postgres",
    "db:test": "node -e \"require('./scripts/test-db.js')\"",
    "db:studio": "bash scripts/studio.sh",
    "db:psql": "docker exec -it genfly-postgres psql -U postgres -d genfly_dev",
    "db:query": "node scripts/query-db.js"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.8.0",
    "@nanostores/react": "^0.7.3",
    "@next/third-parties": "^15.5.5",
    "@octokit/rest": "^21.0.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-toast": "^1.2.14",
    "@supabase/supabase-js": "^2.49.4",
    "@vercel/blob": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "creem": "^0.3.37",
    "drizzle-orm": "^0.40.0",
    "lucide-react": "^0.514.0",
    "nanostores": "^0.10.3",
    "next": "15.2.6",
    "next-auth": "5.0.0-beta.25",
    "pako": "^2.1.0",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-icons": "^5.4.0",
    "react-toastify": "^10.0.6",
    "sharp": "^0.34.2",
    "tailwind-merge": "^2.2.1",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/dom-speech-recognition": "^0.0.4",
    "@types/node": "^22.13.10",
    "@types/pako": "^2.0.3",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "drizzle-kit": "^0.30.5",
    "eslint": "^9.22.0",
    "eslint-config-next": "15.2.0",
    "sass": "^1.80.3",
    "tailwindcss": "^4.1.11",
    "typescript": "5.2.2"
  }
}
